@{
    Layout = null;
}

<head>
    <title>Reset Password - CEMS</title>
    <link rel="stylesheet" href="~/css/loginpage.css" />
</head>

<body>

<div class="login-card">

        <h1>GMC Event Wing</h1>
        <br>
        <h3>Reset your password</h3>

        <form asp-action="SendResetCode" method="post">

            <input name="email" type="email" placeholder="Enter your registered email" required />

            <button type="submit" class="login-btn"> Get a Reset Code </button>

        </form>

        <p class="link" onclick="window.location.href='/Login/LoginPage'"> Go back and login </p>
        
        @if (ViewBag.Error != null)
        {
            <p class="error-message">@ViewBag.Error</p>
        }
</div>

</body>
